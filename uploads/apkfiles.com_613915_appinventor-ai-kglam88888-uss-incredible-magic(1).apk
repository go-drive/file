function handleScroll(){const scrollMaxLeft=imageContainer.scrollLeft;const scrollMaxRight=imageContainer.scrollWidth-imageContainer.clientWidth-imageContainer.scrollLeft;if(scrollMaxLeft<16){scrollLeftButton.classList.add("hide")}else{scrollLeftButton.classList.remove("hide")}
if(scrollMaxRight<16){scrollRightButton.classList.add("hide")}else{scrollRightButton.classList.remove("hide")}}

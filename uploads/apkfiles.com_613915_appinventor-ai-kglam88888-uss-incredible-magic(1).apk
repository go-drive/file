                                          <g opacity="0.6">
                                              <path d="M2.66667 13.3335H13.3333C13.5101 13.3335 13.6797 13.4037 13.8047 13.5288C13.9298 13.6538 14 13.8234 14 14.0002C14 14.177 13.9298 14.3465 13.8047 14.4716C13.6797 14.5966 13.5101 14.6668 13.3333 14.6668H2.66667C2.48986 14.6668 2.32029 14.5966 2.19526 14.4716C2.07024 14.3465 2 14.177 2 14.0002C2 13.8234 2.07024 13.6538 2.19526 13.5288C2.32029 13.4037 2.48986 13.3335 2.66667 13.3335ZM8 1.3335C7.82319 1.3335 7.65362 1.40373 7.5286 1.52876C7.40357 1.65378 7.33333 1.82335 7.33333 2.00016V9.72416L5.80467 8.1955C5.74317 8.13182 5.66961 8.08103 5.58827 8.04609C5.50693 8.01116 5.41945 7.99276 5.33093 7.992C5.24241 7.99123 5.15463 8.00809 5.0727 8.04161C4.99077 8.07514 4.91633 8.12464 4.85374 8.18723C4.79114 8.24983 4.74164 8.32426 4.70812 8.40619C4.6746 8.48812 4.65773 8.57591 4.6585 8.66443C4.65927 8.75295 4.67766 8.84043 4.7126 8.92177C4.74754 9.0031 4.79833 9.07666 4.862 9.13816L7.52867 11.8048C7.59073 11.8666 7.66436 11.9155 7.74533 11.9488C7.82596 11.9827 7.91254 12.0002 8 12.0002C8.08746 12.0002 8.17404 11.9827 8.25467 11.9488C8.33564 11.9155 8.40927 11.8666 8.47133 11.8048L11.138 9.13816C11.2594 9.01243 11.3266 8.84403 11.3251 8.66923C11.3236 8.49443 11.2535 8.32722 11.1299 8.20362C11.0063 8.08001 10.8391 8.0099 10.6643 8.00838C10.4895 8.00686 10.3211 8.07406 10.1953 8.1955L8.66667 9.72416V2.00016C8.66667 1.82335 8.59643 1.65378 8.4714 1.52876C8.34638 1.40373 8.17681 1.3335 8 1.3335Z" fill="black"></path>
                                          </g>
                                      </svg>
                                      <span>${item.ratingString}</span>
                                  </div>
                                  <div class="line_i"></div>

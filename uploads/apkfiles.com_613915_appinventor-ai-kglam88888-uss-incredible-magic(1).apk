<script>
    $(document).ready(function(){$(".ft__menu_ft .ft__menu_ft_title").click(function(){$(this).parent().toggleClass("open")});$(".search_home .form-search input").focus(function(e){e.preventDefault();$(".suggestions-holder").addClass("show-sg");$(".suggestions-holder_post").addClass("show-sg-post");getSearchHistoryFromCookie()});function getSearchHistoryFromCookie(){const cookieString=document.cookie;const cookies=cookieString.split(";");for(let i=0;i<cookies.length;i++){const cookie=cookies[i].trim();if(cookie.startsWith("searchHistory=j")){const cookieValue=decodeURIComponent(cookie.substring("searchHistory=".length));const jsonString=cookieValue.substring(cookieValue.indexOf(":")+1);var searchHistory=JSON.parse(jsonString);searchHistory=searchHistory.reverse();var html=[];if(searchHistory.length==0){$(".suggestions-holder").html(html)}else{var searchHistory=searchHistory.slice(0,5);searchHistory.forEach(function(item,i){html.push(` <div id="${i}" class="s-item"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g opacity="0.6"><path d="M12 21C10.22 21 8.47991 20.4722 6.99987 19.4832C5.51983 18.4943 4.36628 17.0887 3.68509 15.4442C3.0039 13.7996 2.82567 11.99 3.17294 10.2442C3.5202 8.49836 4.37737 6.89472 5.63604 5.63604C6.89472 4.37737 8.49836 3.5202 10.2442 3.17294C11.99 2.82567 13.7996 3.0039 15.4442 3.68509C17.0887 4.36628 18.4943 5.51983 19.4832 6.99987C20.4722 8.47991 21 10.22 21 12C21 14.387 20.0518 16.6761 18.364 18.364C16.6761 20.0518 14.387 21 12 21ZM12 4.5C10.5166 4.5 9.0666 4.93987 7.83323 5.76398C6.59986 6.58809 5.63856 7.75943 5.07091 9.12988C4.50325 10.5003 4.35473 12.0083 4.64411 13.4632C4.9335 14.918 5.64781 16.2544 6.6967 17.3033C7.7456 18.3522 9.08197 19.0665 10.5368 19.3559C11.9917 19.6453 13.4997 19.4968 14.8701 18.9291C16.2406 18.3614 17.4119 17.4001 18.236 16.1668C19.0601 14.9334 19.5 13.4834 19.5 12C19.5 10.0109 18.7098 8.10323 17.3033 6.6967C15.8968 5.29018 13.9891 4.5 12 4.5Z" fill="#0A0A0A" /><path d="M15 12.75H12C11.8019 12.7474 11.6126 12.6676 11.4725 12.5275C11.3324 12.3874 11.2526 12.1981 11.25 12V7C11.25 6.80109 11.329 6.61032 11.4697 6.46967C11.6103 6.32902 11.8011 6.25 12 6.25C12.1989 6.25 12.3897 6.32902 12.5303 6.46967C12.671 6.61032 12.75 6.80109 12.75 7V11.25H15C15.1989 11.25 15.3897 11.329 15.5303 11.4697C15.671 11.6103 15.75 11.8011 15.75 12C15.75 12.1989 15.671 12.3897 15.5303 12.5303C15.3897 12.671 15.1989 12.75 15 12.75Z" fill="#0A0A0A" /></g></svg><span>${item}</span><a href="javascript:void(0);" class="s-item_close"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g opacity="0.38"><path fill-rule="evenodd" clip-rule="evenodd" d="M5.29289 5.29289C5.68342 4.90237 6.31658 4.90237 6.70711 5.29289L12 10.5858L17.2929 5.29289C17.6834 4.90237 18.3166 4.90237 18.7071 5.29289C19.0976 5.68342 19.0976 6.31658 18.7071 6.70711L13.4142 12L18.7071 17.2929C19.0976 17.6834 19.0976 18.3166 18.7071 18.7071C18.3166 19.0976 17.6834 19.0976 17.2929 18.7071L12 13.4142L6.70711 18.7071C6.31658 19.0976 5.68342 19.0976 5.29289 18.7071C4.90237 18.3166 4.90237 17.6834 5.29289 17.2929L10.5858 12L5.29289 6.70711C4.90237 6.31658 4.90237 5.68342 5.29289 5.29289Z" fill="#0F1729" /></g></svg></a></div>`);$(".suggestions-holder").html(html);rebuildDOM()})}}}}
$(".open_search").click(function(){$("#search-holder").addClass("open");$("#search-holder input").focus();getSearchHistoryFromCookie();$(".suggestions-holder").addClass("show-sg");$(".suggestions-holder_post").addClass("show-sg-post")});$(".close_search").on("click",function(e){$("#search-holder").removeClass("open")});function rebuildDOM(){const sItems=document.querySelectorAll(".s-item");sItems.forEach(function(sItem){const closeButton=sItem.querySelector(".s-item_close");closeButton.addEventListener("click",function(event){if(sItem){const value=sItem.querySelector("span").textContent;$.ajax({url:`${domain}/cookieS`,method:"GET",data:{textSearch:value,},success:function(response){if(response.code==1){getSearchHistoryFromCookie()}},error:function(xhr,status,error){console.error("Lỗi khi thực hiện yêu cầu:",error)},})}})})}
var timeSearch=0,tsearch="";$(".form-search input[name=s]").on("input",function(e){clearTimeout(timeSearch);$this=$(this);timeSearch=setTimeout(function(){var strInput=$this.val(),query=strInput.toLowerCase();if(query.length>0){$.ajax({url:`${domain}/suggest`,data:{s:query},method:"POST",success:function(rs){var html=[];const data=rs.data;let suggests=rs.suggest||[];suggests=suggests.map((t)=>t.toLowerCase());if(data.length>0){html.push(`<div class="holder_post_title">${found} <strong>${data.length}</strong> ${results} </div>`);data.forEach((item)=>{let title=item.title||"";title=title.toLowerCase();domain="https://apkhello.net"
if(suggests.includes(title))
suggests=suggests.filter((t)=>t!==title);html.push(`<a href="${domain}/${item.slug}/${item.packageName}/" title="${item.title}" class="item">
                          <figure class="thumb">
                              <img src="${item.iconUrl}" alt="${item.title}">
